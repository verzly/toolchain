{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "datarose.toml",
  "description": "JSON Schema representation for datarose.toml. The Verzly executable performs offline runtime validation with its embedded Rust validator; this schema mirrors the public config contract for review and optional TOML editor integrations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "quality": {
      "$ref": "#/$defs/quality"
    },
    "release": {
      "$ref": "#/$defs/release"
    },
    "rust_cache": {
      "$ref": "#/$defs/rustCache"
    },
    "tauri_release": {
      "$ref": "#/$defs/tauriRelease"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "rust",
              "js",
              "javascript",
              "typescript",
              "vue",
              "php"
            ]
          }
        },
        "js_runner": {
          "type": "string",
          "enum": [
            "aube",
            "npm",
            "pnpm",
            "yarn",
            "bun"
          ]
        },
        "rust": {
          "$ref": "#/$defs/rustQuality"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "target_branch": {
          "type": "string"
        },
        "source_repository": {
          "type": "string"
        },
        "secret_name": {
          "type": "string"
        },
        "release_all": {
          "type": "boolean"
        },
        "manage_cargo_packages": {
          "type": "boolean"
        },
        "manage_workflows": {
          "type": "boolean"
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/releaseTarget"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "required": [
              "source_repository",
              "targets"
            ]
          }
        }
      ]
    },
    "releaseTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "same-repo",
            "distribution-repo",
            "workspace"
          ]
        },
        "workflow": {
          "type": "string",
          "enum": [
            "custom",
            "managed"
          ]
        },
        "source_kind": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "target_repository": {
          "type": "string"
        },
        "source_repository": {
          "type": "string"
        },
        "distribution_path": {
          "type": "string"
        },
        "cargo_binary": {
          "type": "string"
        },
        "cargo_package": {
          "type": "string"
        },
        "cargo_out_dir": {
          "type": "string"
        },
        "cargo_targets": {
          "$ref": "#/$defs/stringArray"
        },
        "prepare_commands": {
          "$ref": "#/$defs/stringArray"
        },
        "version_files": {
          "type": "boolean"
        },
        "version_file": {
          "type": "string"
        },
        "version_file_optional": {
          "type": "boolean"
        },
        "version_key": {
          "type": "string"
        },
        "version_value": {
          "type": "string"
        },
        "source_tag_prefix": {
          "type": "string"
        },
        "release_tag_prefix": {
          "type": "string"
        },
        "release_name_prefix": {
          "type": "string"
        },
        "source_release": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "#/$defs/releaseRuntime"
            }
          ]
        },
        "generate_notes": {
          "type": "boolean"
        },
        "floating_tags": {
          "type": "boolean"
        },
        "latest_tag": {
          "type": "boolean"
        },
        "next_tag": {
          "type": "boolean"
        },
        "include_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "include_paths": {
          "$ref": "#/$defs/stringArray"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/versionFile"
          }
        },
        "release": {
          "$ref": "#/$defs/releaseRuntime"
        },
        "github": {
          "$ref": "#/$defs/githubRelease"
        }
      }
    },
    "releaseRuntime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_branch": {
          "type": "string"
        },
        "branch_prefix": {
          "type": "string"
        },
        "tag_prefix": {
          "type": "string"
        },
        "tag_suffix": {
          "type": "string"
        },
        "name_prefix": {
          "type": "string"
        },
        "name_suffix": {
          "type": "string"
        },
        "commit_message": {
          "type": "string"
        },
        "merge_message": {
          "type": "string"
        },
        "cleanup": {
          "type": "boolean"
        },
        "latest": {
          "type": "boolean"
        },
        "floating_tags": {
          "type": "boolean"
        },
        "latest_tag": {
          "type": "boolean"
        },
        "next_tag": {
          "type": "boolean"
        },
        "latest_tag_name": {
          "type": "string"
        },
        "next_tag_name": {
          "type": "string"
        }
      }
    },
    "githubRelease": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_repository": {
          "type": "string"
        },
        "source_repository": {
          "type": "string"
        },
        "source_tag_prefix": {
          "type": "string"
        },
        "source_tag_suffix": {
          "type": "string"
        },
        "generate_notes": {
          "type": "boolean"
        },
        "notes_body": {
          "type": "string"
        },
        "notes": {
          "$ref": "#/$defs/githubNotes"
        }
      }
    },
    "githubNotes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "github",
            "scoped"
          ]
        },
        "include_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "include_paths": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "versionFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "toml",
            "json",
            "cargo-lock-package",
            "text"
          ]
        },
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "value_type": {
          "type": "string",
          "enum": [
            "string",
            "integer"
          ]
        },
        "search": {
          "type": "string"
        },
        "replace": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "rustCache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cache": {
          "$ref": "#/$defs/rustCacheCache"
        },
        "cargo": {
          "$ref": "#/$defs/rustCacheCargo"
        },
        "generated": {
          "$ref": "#/$defs/rustCacheGenerated"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "rustCacheCache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "redirect_cargo_home": {
          "type": "boolean"
        },
        "redirect_gradle": {
          "type": "boolean"
        }
      }
    },
    "rustCacheCargo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_dir": {
          "type": "string"
        }
      }
    },
    "rustCacheGenerated": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "tauriRelease": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project": {
          "$ref": "#/$defs/tauriProject"
        },
        "build": {
          "$ref": "#/$defs/tauriBuild"
        }
      }
    },
    "tauriProject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string"
        },
        "frontend_install": {
          "type": "string"
        }
      }
    },
    "tauriBuild": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "out_dir": {
          "type": "string"
        },
        "cache_dir": {
          "type": "string"
        }
      }
    },
    "rustQuality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manage_cargo_lints": {
          "type": "boolean"
        },
        "manage_clippy_config": {
          "type": "boolean"
        },
        "lint_profile": {
          "type": "string",
          "enum": [
            "strict",
            "relaxed"
          ]
        },
        "lints": {
          "$ref": "#/$defs/rustQualityLints"
        }
      }
    },
    "rustQualityLints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rust": {
          "$ref": "#/$defs/lintLevelMap"
        },
        "clippy": {
          "$ref": "#/$defs/lintLevelMap"
        }
      }
    },
    "lintLevelMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": [
          "allow",
          "warn",
          "deny",
          "forbid"
        ]
      }
    }
  }
}
